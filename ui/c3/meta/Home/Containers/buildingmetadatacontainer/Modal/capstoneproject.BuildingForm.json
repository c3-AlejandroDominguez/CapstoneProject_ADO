{
  "type": "UiSdlConnected<UiSdlForm>",
  "component": {
    "title": {
      "title": "Building Information"
    },
    "subtitle": {
      "title": "Update building details"
    },
    "submitDataSpec": {
      "dataType": "Building",
      "actionName": "merge",
      "submitArgument": "this"
    },
    "clearOnCancel": true,
    "width": 100,
    "dataSpec": {
      "dataType": "Building",
      "actionName": "get",
      "contextVars": {
        "buildingId": {
          "type": "UiSdlApplicationStateValueParam",
          "id": "capstoneproject.UiSdlApplicationStateSB",
          "path": "rowRecord"
        }
      },
      "args": {
        "this": {
          "id": "${buildingId}"
        }
      },
      "fieldSets": {
        "type": "[UiSdlFormFieldSet]",
        "value": [
          {
            "type": "UiSdlFormFieldSet",
            "fields": [
              {
                "inputElement": {
                  "type": "UiSdlTextInput",
                  "placeholder": "Update which city the building is located in"
                },
                "dataPropSpecs": [
                  {
                    "prop": "value",
                    "dataPath": "city.id"
                  }
                ],
                "fieldName": "city",
                "label": "City ID",
                "required": false
              },
              {
                "inputElement": {
                  "type": "UiSdlNumberInput",
                  "placeholder": "Update latitude"
                },
                "dataPropSpecs": [
                  {
                    "prop": "value",
                    "dataPath": "latitude"
                  }
                ],
                "fieldName": "latitude",
                "label": "Latitude",
                "required": false
              },
              {
                "inputElement": {
                  "type": "UiSdlNumberInput",
                  "placeholder": "Update longitude"
                },
                "dataPropSpecs": [
                  {
                    "prop": "value",
                    "dataPath": "longitude"
                  }
                ],
                "fieldName": "longitude",
                "label": "Longitude",
                "required": false
              }
            ]
          }
        ]
      }
    }
  }
}
